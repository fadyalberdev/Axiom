@startuml
top to bottom direction
skinparam backgroundColor white
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 35
skinparam ranksep 40

title AXIOM V2 Class Diagram

class AppMain {
  +register_routers()
  +configure_cors()
  +lifespan()
}

class SecurityHeadersMiddleware {
  +dispatch(request, call_next)
}

class RateLimitMiddleware {
  +dispatch(request, call_next)
}

class Settings {
  +SUPABASE_URL
  +STRIPE_SECRET_KEY
  +OLLAMA_BASE_URL
  +RENT_BOOKING_FEE_EGP
}

class ListingRouter {
  +list_listings()
  +get_listing()
  +create_listing()
  +update_listing()
  +delete_listing()
  +apply_to_listing()
}

class AdminRouter {
  +admin_login()
  +get_stats()
  +approve_listing()
  +reject_listing()
  +verify_user()
  +review_fraud()
}

class BookingRouter {
  +create_payment_intent()
  +sync_payment()
  +confirm_booking()
  +refund_booking()
  +vacate_booking()
}

class LeadsRouter {
  +create_lead()
  +list_admin_leads()
}

class AIRouter {
  +chat()
  +generate_description()
  +validate_amenity()
  +compatibility()
}

class SubscriptionService {
  +ensure_subscription()
  +get_plan_limits()
  +pause_excess_for_user()
  +delete_expired_paused_once()
}

class ListingSchemas {
  +CreateListingRequest
  +UpdateListingRequest
  +ListingBriefResponse
  +ListingDetailResponse
  +ApplicationDetailResponse
}

class InteractionSchemas {
  +CreateLeadRequest
  +CreateViewingRequest
  +CreatePaymentIntentRequest
  +SyncPaymentRequest
}

class AdminSchemas {
  +AdminLoginRequest
  +RejectListingRequest
  +VerifyUserRequest
  +AdminStatsResponse
}

class RAGRetriever {
  +retrieve()
  +hybrid_search()
  +format_context()
}

class RAGModels {
  +Chunk
  +Citation
  +RAGResponse
}

class ApiClient {
  +get()
  +post()
  +put()
  +delete()
}

class AuthStore {
  +login()
  +signup()
  +logout()
  +initialize()
}

class AddListingModal {
  +collect_listing_fields()
  +generate_description()
  +submit_listing()
}

class BookingModal {
  +create_payment_intent()
  +confirm_card_payment()
  +sync_payment()
}

class AdminDashboard {
  +load_stats()
  +approve_listing()
  +reject_listing()
  +verify_user()
  +review_fraud()
}

AppMain --> SecurityHeadersMiddleware
AppMain --> RateLimitMiddleware
AppMain --> Settings
AppMain --> ListingRouter
AppMain --> AdminRouter
AppMain --> BookingRouter
AppMain --> LeadsRouter
AppMain --> AIRouter

ListingRouter --> ListingSchemas
ListingRouter --> SubscriptionService
AdminRouter --> AdminSchemas
AdminRouter --> SubscriptionService
BookingRouter --> InteractionSchemas
LeadsRouter --> InteractionSchemas
AIRouter --> RAGRetriever
RAGRetriever --> RAGModels

AuthStore --> ApiClient
AddListingModal --> ApiClient
BookingModal --> ApiClient
AdminDashboard --> ApiClient
AddListingModal ..> ListingSchemas
BookingModal ..> InteractionSchemas
AdminDashboard ..> AdminSchemas
@enduml
