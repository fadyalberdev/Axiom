@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam sequenceMessageAlign center
title User Enquiry, Booking, and Shared-Housing Sequence

actor User
participant "Next.js UI" as UI
participant "Auth Store" as Auth
participant "FastAPI" as API
participant "Listings Router" as Listings
participant "Leads Router" as Leads
participant "Bookings Router" as Bookings
participant "AI Router" as AI
database "Supabase" as DB
participant "Stripe" as Stripe
participant "Ollama" as Ollama
participant "WhatsApp" as WhatsApp

User -> UI: Browse or ask AI search
UI -> API: GET /api/listings
API -> Listings: apply filters
Listings -> DB: select active listings
DB --> Listings: listing rows
Listings --> UI: listing cards

User -> UI: Open property detail
UI -> API: GET /api/listings/{id}
API -> Listings: fetch detail
Listings -> DB: listing, owner, housemates, similar listings
DB --> Listings: detail data
Listings --> UI: detail response

alt WhatsApp enquiry
  User -> UI: Contact owner
  UI -> Auth: require signed-in user
  UI -> API: POST /api/leads
  API -> Leads: validate listing and contact phone
  Leads -> DB: upsert lead
  DB --> Leads: lead row
  Leads --> UI: wa_me_url
  UI -> WhatsApp: open chat link
else Rent booking deposit
  User -> UI: Book now
  UI -> API: POST /api/bookings/payment-intent
  API -> Bookings: validate active rent listing
  Bookings -> DB: read listing and owner
  Bookings -> Stripe: create PaymentIntent
  Stripe --> Bookings: client_secret
  Bookings -> DB: mark listing pending_payment
  Bookings --> UI: client_secret and fee
  UI -> Stripe: confirmCardPayment
  Stripe --> API: payment_intent.succeeded webhook
  API -> Bookings: create booking from paid intent
  Bookings -> DB: insert booking, insert payment, mark listing booked
  UI -> API: POST /api/bookings/sync-payment
  API --> UI: booking summary
else Shared housing application
  User -> UI: Check compatibility
  UI -> API: POST /api/ai/compatibility
  API -> AI: build listing and user preference prompt
  AI -> Ollama: score compatibility
  Ollama --> AI: score and reasons
  AI --> UI: compatibility result
  User -> UI: Submit application
  UI -> API: POST /api/listings/{id}/apply
  API -> Listings: validate shared housing listing
  Listings -> DB: insert listing_applications
  Listings -> DB: notify owner
  Listings --> UI: application status
end
@enduml
