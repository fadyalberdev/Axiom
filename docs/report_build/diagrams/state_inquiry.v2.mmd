stateDiagram-v2
    [*] --> Pending: owner submits listing
    Pending --> Active: auto approval or admin approve
    Pending --> Rejected: admin reject or fraud review reject
    Rejected --> Pending: owner edits and resubmits

    Active --> PendingPayment: renter starts Stripe checkout
    PendingPayment --> Active: payment canceled or sync fails
    PendingPayment --> Booked: payment_intent succeeded
    Booked --> Active: refund or tenant vacates

    Active --> Sold: owner or admin marks sold
    Active --> Rented: owner or admin marks rented
    Active --> Paused: subscription over plan cap
    Paused --> Active: plan restored and listing reactivated
    Paused --> Deleted: grace period expires

    Pending --> Deleted: owner or admin soft delete
    Rejected --> Deleted: owner or admin soft delete
    Active --> Deleted: owner or admin soft delete

    Sold --> [*]
    Rented --> [*]
    Deleted --> [*]

    state "pending_payment" as PendingPayment
    state "active" as Active
    state "pending" as Pending
    state "rejected" as Rejected
    state "booked" as Booked
    state "paused" as Paused
    state "sold" as Sold
    state "rented" as Rented
    state "soft deleted" as Deleted
