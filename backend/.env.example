# AXIOM V2 Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Get SUPABASE_SERVICE_ROLE_KEY and JWT_SECRET from:
#   Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://pgaqqseqwtgsuihbswnv.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBnYXFxc2Vxd3Rnc3VpaGJzd252Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI0NjI0MDEsImV4cCI6MjA4ODAzODQwMX0.gwhEaL1VihBKp2FO7vlgHqBPI-8qFNjo6-lzGkmmzpY
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
JWT_SECRET=your-jwt-secret-here

FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Ollama local inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=axiom-llm
OLLAMA_EMBED_MODEL=nomic-embed-text

# Admin panel credentials (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
# Separate JWT signing secret for admin tokens (generate with: openssl rand -hex 32)
ADMIN_JWT_SECRET=change-me-in-production

# Optional — leave empty to disable
REDIS_URL=
SENTRY_DSN=

# Stripe test mode
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Transactional email (Resend) — powers the "Contact Sales Team" form.
# Get an API key at https://resend.com/api-keys. Leave RESEND_API_KEY empty to disable.
# EMAIL_FROM must use a domain you've verified in Resend (or the onboarding@resend.dev sandbox).
RESEND_API_KEY=
EMAIL_FROM=Axiom <onboarding@resend.dev>
# Fallback inbox for sales enquiries when an agency has no email on file.
SUPPORT_EMAIL=
